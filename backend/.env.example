# Example environment variables for backend
PORT=5000
# SMTP settings (optional). If absent, messages will be logged to console.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM=you@example.com
EMAIL_TO=you@example.com
# Example Mailtrap settings (for testing)
# Sign up at https://mailtrap.io and use the SMTP credentials provided for your inbox
#MAILTRAP_HOST=smtp.mailtrap.io
#MAILTRAP_PORT=2525
#MAILTRAP_USER=your-mailtrap-username
#MAILTRAP_PASS=your-mailtrap-password
